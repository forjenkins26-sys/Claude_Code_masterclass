{
  "name": "facebook-playwright-automation",
  "version": "1.0.0",
  "description": "Production-ready Playwright framework for Facebook automation",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:ui:headed": "playwright test tests/ui/ --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.facebook.com",
    "install:browsers": "playwright install",
    "typecheck": "tsc --noEmit",
    "ai:rca": "ts-node ../agent-factory-cli/ai-agents/cli.ts rca test-results/results.json",
    "ai:flaky": "ts-node ../agent-factory-cli/ai-agents/cli.ts flaky ./runs",
    "ai:heal": "ts-node ../agent-factory-cli/ai-agents/cli.ts heal --report test-results/results.json",
    "ai:triage": "ts-node ../agent-factory-cli/ai-agents/cli.ts triage test-results/results.json ./runs",
    "ai:dashboard": "ts-node ../agent-factory-cli/ai-agents/cli.ts dashboard",
    "rules:check": "node scripts/rule-engine.js",
    "rules:changed": "node scripts/rule-engine.js --changed",
    "rules:staged": "node scripts/rule-engine.js --staged"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "facebook",
    "pom"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^22.5.0",
    "allure-playwright": "^3.10.0",
    "typescript": "^5.5.4"
  }
}
