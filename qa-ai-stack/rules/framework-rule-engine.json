{
  "sourceRoots": [
    "src/pages",
    "src/utils",
    "src/fixtures",
    "src/data",
    "tests/ui",
    "tests/setup"
  ],
  "placementRules": [
    {
      "id": "page-placement",
      "fileRegex": "Page\\.ts$",
      "mustBeUnder": "src/pages",
      "message": "Page objects must live in src/pages"
    },
    {
      "id": "util-placement",
      "fileRegex": "helpers\\.ts$",
      "mustBeUnder": "src/utils",
      "message": "Utility helpers must live in src/utils"
    },
    {
      "id": "spec-placement",
      "fileRegex": "\\.spec\\.ts$",
      "mustBeUnder": "tests",
      "message": "Spec files must live under tests/"
    }
  ],
  "folderNamingRules": [
    {
      "id": "pages-filename",
      "folder": "src/pages",
      "allowedFileRegex": [
        "^[A-Z][A-Za-z0-9]*Page\\.ts$"
      ],
      "message": "Only *Page.ts files are allowed in src/pages"
    },
    {
      "id": "tests-filename",
      "folder": "tests/ui",
      "allowedFileRegex": [
        "^[a-z0-9-]+\\.spec\\.ts$"
      ],
      "message": "Tests in tests/ui must use lower-case *.spec.ts naming"
    }
  ],
  "contentRules": [
    {
      "id": "tests-use-describe",
      "folder": "tests/ui",
      "fileRegex": "\\.spec\\.ts$",
      "requireRegex": [
        "test\\.describe\\("
      ],
      "message": "Specs should group scenarios with test.describe"
    },
    {
      "id": "tests-tags",
      "folder": "tests/ui",
      "fileRegex": "\\.spec\\.ts$",
      "requireRegex": [
        "@smoke|@regression|@P0|@P1|@P2"
      ],
      "message": "Add tags (@smoke/@regression/@P0/@P1/@P2) in describe titles"
    },
    {
      "id": "no-xpath-locator",
      "folder": "src/pages",
      "fileRegex": "Page\\.ts$",
      "forbidRegex": [
        "locator\\(\\s*['\"`]\\s*(//|\\.\\.?/|xpath=)"
      ],
      "message": "Selector policy: XPath is forbidden (AH Rule 11). Use getByRole/getByLabel/getByTestId or a stable id."
    },
    {
      "id": "no-positional-locator",
      "folder": "src/pages",
      "fileRegex": "Page\\.ts$",
      "forbidRegex": [
        "locator\\([^)]*nth-child",
        "locator\\([^)]*nth-of-type",
        "\\.nth\\(\\s*\\d+\\s*\\)"
      ],
      "message": "Selector policy: positional selectors (nth-child/nth-of-type/.nth(n)) are forbidden — brittle, break on DOM change. Use an accessible-name locator."
    },
    {
      "id": "no-class-locator",
      "folder": "src/pages",
      "fileRegex": "Page\\.ts$",
      "forbidRegex": [
        "locator\\(\\s*['\"`]\\s*\\.[A-Za-z]"
      ],
      "message": "Selector policy: CSS class locators (.class) are forbidden — styling changes break them. Use getByRole/getByLabel/getByTestId."
    },
    {
      "id": "no-dynamic-id-locator",
      "folder": "src/pages",
      "fileRegex": "Page\\.ts$",
      "forbidRegex": [
        "locator\\(\\s*['\"`]\\s*#[A-Za-z-]*\\d{3,}"
      ],
      "message": "Selector policy: generated/dynamic IDs (e.g. #id-23948) are forbidden — non-deterministic. Use a stable accessible locator."
    }
  ],
  "warningRules": [
    {
      "id": "no-console-log",
      "folder": "src",
      "fileRegex": "\\.ts$",
      "forbidRegex": [
        "console\\.log\\("
      ],
      "message": "Use helpers.ts utilities instead of console.log"
    }
  ]
}
