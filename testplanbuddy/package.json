{
  "name": "testplanbuddy",
  "version": "1.0.0",
  "description": "Jira issue → QA Test Plan generator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm run build",
    "handshake": "node -e \"const h=require('http');h.get('http://localhost:3001/api/handshake',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log(d))})\"",
    "setup": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
