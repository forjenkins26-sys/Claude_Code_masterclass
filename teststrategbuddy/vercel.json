{
  "version": 2,
  "builds": [
    {
      "src": "client/dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/dist/$1"
    }
  ],
  "env": {
    "JIRA_URL": "@jira_url",
    "JIRA_EMAIL": "@jira_email",
    "JIRA_TOKEN": "@jira_token",
    "GROQ_KEY": "@groq_key"
  }
}
